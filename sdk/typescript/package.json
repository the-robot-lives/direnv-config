{
  "name": "@noizu/direnv-config",
  "version": "0.1.0",
  "description": "TypeScript/Node.js SDK for direnv-config (dc) — read and write YAML-backed directory configuration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "author": "Keith Brings <keith.brings@noizu.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/noizu/direnv-config",
    "directory": "sdk/typescript"
  },
  "homepage": "https://github.com/noizu/direnv-config#readme",
  "bugs": {
    "url": "https://github.com/noizu/direnv-config/issues"
  },
  "keywords": [
    "direnv",
    "config",
    "yaml",
    "environment",
    "configuration",
    "dotenv"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
