{
  "name": "noizu/direnv-config",
  "description": "PHP SDK for direnv-config (dc) — read YAML-backed directory configuration",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": { "Noizu\\DirenvConfig\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Noizu\\DirenvConfig\\Tests\\": "tests/" }
  },
  "require": {
    "php": ">=8.1",
    "symfony/yaml": "^6.0|^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "minimum-stability": "stable"
}
