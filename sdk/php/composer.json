{
  "name": "noizu/direnv-config",
  "description": "PHP SDK for direnv-config (dc) — read and write YAML-backed directory configuration",
  "type": "library",
  "license": "MIT",
  "keywords": ["direnv", "config", "yaml", "environment", "configuration", "dotenv"],
  "homepage": "https://github.com/noizu/direnv-config",
  "authors": [
    {
      "name": "Keith Brings",
      "email": "keith.brings@noizu.com"
    }
  ],
  "support": {
    "issues": "https://github.com/noizu/direnv-config/issues",
    "source": "https://github.com/noizu/direnv-config/tree/main/sdk/php"
  },
  "autoload": {
    "psr-4": { "Noizu\\DirenvConfig\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Noizu\\DirenvConfig\\Tests\\": "tests/" }
  },
  "require": {
    "php": ">=8.1",
    "symfony/yaml": "^6.0|^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
