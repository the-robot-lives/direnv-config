# demo/root/projects/terraform/.envrc — Terraform / IaC directory
# Inherits: cluster, cloudflare, tab, build, npl, services
# Demonstrates: heavy pruning, unset, batched --no-bump writes
source_up

# --- Prune: remove everything we don't need ---
# Terraform manages infra — doesn't run workloads, doesn't need services, tab, build, npl
dc_prune --no-bump cluster
dc_prune --no-bump services
dc_prune --no-bump npl
dc_prune --no-bump build

# --- Keep cloudflare (Terraform's Cloudflare provider needs it) ---
# But prune the tunnel sub-branch — Terraform doesn't manage tunnels
dc_prune --no-bump cloudflare tunnel

# --- Unset individual keys we don't need ---
dc_unset --no-bump cloudflare zone_id_trl

# --- Tab: minimal override ---
dc_yaml --no-bump tab <<'YAML'
theme: nord
status: terraform
emoji: wrench
YAML

# --- Add terraform-specific config ---
dc_yaml --no-bump terraform <<'YAML'
workspace: production
backend:
  type: s3
  bucket: noizu-tf-state
  region: us-east-1
  lock_table: noizu-tf-locks
  encrypt: true
providers:
  cloudflare:
    version: "~> 4.0"
  aws:
    version: "~> 5.0"
    region: us-east-1
YAML

dc_yaml --no-bump _dc <<'YAML'
flatten:
  terraform.workspace: TF_WORKSPACE
  terraform.backend.bucket: TF_STATE_BUCKET
  terraform.backend.region: TF_STATE_REGION
  cloudflare.account_id: CF_ACCOUNT_ID
  cloudflare.zone_id: CF_ZONE_ID
  cloudflare.api_token: CF_API_TOKEN
YAML

# --- Single version bump for all the above ---
dc_bump

dc_export
