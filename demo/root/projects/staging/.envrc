# demo/root/projects/staging/.envrc — Staging environment
# Inherits: cluster, cloudflare, tab, build, npl, services
# Demonstrates: --replace-key (full branch replacement), --replace (full config replacement)
source_up

# --- Replace entire cloudflare config ---
# Parent had production account_id, zone_id, tunnel, etc.
# --replace wipes ALL keys in cloudflare config and writes only what's here.
# Use when the child's config is NOT a superset of the parent's.
dc_yaml cloudflare --replace <<'YAML'
account_id: staging-cf-account
zone_id: staging-zone-id
tunnel:
  enabled: false
YAML

# Parent had secrets for cloudflare — need new ones for staging
dc_yaml cloudflare --layer secrets --replace <<'YAML'
api_token: staging-api-token
YAML

# --- Replace just cluster.node_pool branch ---
# Parent had: node_pool.min=2, node_pool.max=8, node_pool.instance_type=m5.xlarge
# After: node_pool is ONLY min=1, max=3 — instance_type is gone
# But cluster.name, cluster.kubeconfig, etc. are preserved (only node_pool replaced)
dc_yaml cluster --replace-key node_pool <<'YAML'
node_pool:
  min: 1
  max: 3
YAML

# --- Deep merge: override build env ---
dc_yaml build <<'YAML'
env: staging
push_on_build: true
YAML

# --- Override tab ---
dc_yaml tab <<'YAML'
theme: safe
status: staging
emoji: construction
YAML

# --- Add staging-specific config ---
dc_yaml project <<'YAML'
namespace: staging-ns
domain: staging.noizu.com
ttl: 7200
cleanup:
  enabled: true
  max_age_hours: 72
YAML

dc_yaml _dc <<'YAML'
flatten:
  project.namespace: KUBE_NAMESPACE
  project.domain: APP_DOMAIN
  project.ttl: APP_TTL
YAML

dc_export
