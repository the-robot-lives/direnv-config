# demo/root/projects/apps/.envrc — Multi-app incubator
# Inherits: cluster, cloudflare, tab, build, npl, services
# Demonstrates: multiple new named configs, deep merge into inherited, secrets scaffold
source_up

# --- Override build for apps-specific settings ---
dc_yaml build <<'YAML'
env: production
registry: ghcr.io/the-robot-lives
push_on_build: true
platforms:
  - linux/amd64
  - linux/arm64
YAML

# --- Tab ---
dc_yaml tab <<'YAML'
theme: tokyo-night
status: apps
YAML

# --- Per-app named configs: each app gets its own YAML ---

dc_yaml app-codefresh <<'YAML'
domain: codefre.sh
namespace: apps-ns
port: 4001
features:
  auth: github
  billing: stripe
  analytics: true
image:
  backend: codefre.sh/backend
  frontend: codefre.sh/frontend
YAML

dc_yaml app-therobotlives <<'YAML'
domain: therobotlives.com
namespace: apps-ns
port: 4002
features:
  auth: magic-link
  cms: true
image:
  frontend: therobotlives.com/frontend
YAML

dc_yaml app-noizurpg <<'YAML'
domain: noizurpg.com
namespace: apps-ns
port: 4003
features:
  auth: github
  multiplayer: true
  websockets: true
image:
  backend: noizurpg.com/backend
  frontend: noizurpg.com/frontend
  ws: noizurpg.com/ws-server
YAML

# --- Secrets scaffold for all apps ---
dc_yaml app-codefresh --layer secrets --if-missing <<'YAML'
stripe_key: ""
github_client_id: ""
github_client_secret: ""
YAML

dc_yaml app-therobotlives --layer secrets --if-missing <<'YAML'
magic_link_key: ""
cms_api_key: ""
YAML

dc_yaml app-noizurpg --layer secrets --if-missing <<'YAML'
github_client_id: ""
github_client_secret: ""
session_secret: ""
YAML

# --- Flatten: per-app configs namespaced ---
dc_yaml _dc <<'YAML'
flatten:
  app-codefresh.domain: CODEFRESH_DOMAIN
  app-codefresh.port: CODEFRESH_PORT
  app-therobotlives.domain: TRL_DOMAIN
  app-therobotlives.port: TRL_PORT
  app-noizurpg.domain: NOIZURPG_DOMAIN
  app-noizurpg.port: NOIZURPG_PORT
  build.registry: DOCKER_REGISTRY
YAML

dc_export
