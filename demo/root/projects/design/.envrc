# demo/root/projects/design/.envrc — Design project
# Inherits: cluster, cloudflare, tab, build, npl, services
# Demonstrates: merge, prune, set, layer overrides
source_up

# --- Deep merge: override tab theme + add keys ---
# Parent (projects) had: theme=catppuccin, status=projects
# After: theme=rose-pine, status=design (overwritten), emoji=palette (new)
dc_yaml tab <<'YAML'
theme: rose-pine
status: design
emoji: palette
YAML

# --- Prune: remove configs this project doesn't need ---
# npl config is irrelevant to the design project
dc_prune npl

# --- Deep merge: add project-specific config ---
dc_yaml project <<'YAML'
namespace: design-ns
domain: design.noizu.com
features:
  hot_reload: true
  debug_panel: true
  analytics: false
YAML

# --- Deep merge into inherited services: override just postgres pool ---
# Parent had full postgres + redis config — siblings preserved
dc_yaml services <<'YAML'
postgres:
  pool_size: 5
  database: design_dev
YAML

# --- Set individual key on the local (runtime) layer ---
dc_set tab status "ready"

# --- Flatten rules for new keys ---
dc_yaml _dc <<'YAML'
flatten:
  project.namespace: KUBE_NAMESPACE
  project.domain: APP_DOMAIN
YAML

dc_export
