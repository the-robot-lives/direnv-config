# demo/root/.envrc — Top-level config, no parent chain
# Defines five named configs: cluster, cloudflare, tab, build, npl
# Also defines flattening rules in _dc config
# No eval "$(dc-init)" needed — direnv stdlib extension loads dc functions automatically

# --- Named config: cluster ---
dc_yaml cluster <<'YAML'
name: noizu
kubeconfig: ~/.kube/noizu/config
context: noizu
region: us-east-1
node_pool:
  min: 2
  max: 8
  instance_type: m5.xlarge
YAML

# --- Named config: cloudflare ---
dc_yaml cloudflare <<'YAML'
account_id: a75e7459...
zone_id: 46014d24...
zone_id_trl: 9793b993...
access:
  client_id: 7ebfc690...access
tunnel:
  enabled: true
  name: noizu-tunnel
YAML

# --- Named config: cloudflare secrets (separate layer, seed only) ---
dc_yaml cloudflare --layer secrets --if-missing <<'YAML'
api_token: ""
access:
  client_secret: ""
YAML

# --- Named config: tab ---
dc_yaml tab <<'YAML'
theme: kanagawa
status: idle
YAML

# --- Named config: build ---
dc_yaml build <<'YAML'
env: prod
registry: ghcr.io/noizu
push_on_build: false
YAML

# --- Named config: npl ---
dc_yaml npl <<'YAML'
project: noizu-infra
YAML

# --- Flattening rules: maps named config keys → env vars ---
dc_yaml _dc <<'YAML'
flatten:
  cluster.kubeconfig: KUBECONFIG
  cluster.context: KUBECTX_CURRENT_CONTEXT
  cluster.name: CLUSTER_NAME
  cluster.region: CLUSTER_REGION
  cloudflare.account_id: CF_ACCOUNT_ID
  cloudflare.zone_id: CF_ZONE_ID
  cloudflare.zone_id_trl: CF_ZONE_ID_THEROBOTLIVES
  cloudflare.api_token: CF_API_TOKEN
  cloudflare.access.client_id: CF_ACCESS_CLIENT_ID
  cloudflare.access.client_secret: CF_ACCESS_CLIENT_SECRET
  build.env: BUILD_ENV
  build.registry: DOCKER_REGISTRY
  npl.project: NPL_PROJECT
  tab.*: TAB_*
YAML

dc_export
