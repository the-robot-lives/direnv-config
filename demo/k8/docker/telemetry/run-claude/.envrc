# demo/k8/docker/telemetry/run-claude/.envrc — Independent compose stack (no source_up)
# Demonstrates: standalone config store, flat eval config

dc_yaml --no-bump eval <<'YAML'
project_prefix: run-claude
compose_project_name: run-claude-infra
volume_prefix: run-claude
network_name: run-claude-network
network_driver: bridge
timescaledb_user: postgres
signoz_port: 6005
phoenix_port: 6006
phoenix_grpc_port: 6317
otel_grpc_port: 4317
otel_http_port: 4318
fluent_bit_port: 24224
zookeeper_tag: "3.7.1"
clickhouse_tag: "25.5.6"
schema_migrator_tag: v0.129.12
otel_collector_tag: v0.129.12
signoz_tag: v0.104.0
timescaledb_tag: "2.23.1-pg17"
phoenix_tag: "12.18.0"
fluent_bit_tag: "3.2"
YAML

dc_yaml --no-bump eval --layer secrets --if-missing <<'YAML'
timescaledb_password: ""
YAML

dc_yaml --no-bump _dc <<'YAML'
flatten:
  eval.project_prefix: PROJECT_PREFIX
  eval.compose_project_name: COMPOSE_PROJECT_NAME
  eval.volume_prefix: VOLUME_PREFIX
  eval.network_name: NETWORK_NAME
  eval.network_driver: NETWORK_DRIVER
  eval.timescaledb_user: EVAL_TIMESCALEDB_USER
  eval.timescaledb_password: EVAL_TIMESCALEDB_PASSWORD
  eval.signoz_port: EVAL_SIGNOZ_PORT
  eval.phoenix_port: EVAL_PHOENIX_PORT
  eval.phoenix_grpc_port: EVAL_PHOENIX_GRPC_PORT
  eval.otel_grpc_port: EVAL_OTEL_GRPC_PORT
  eval.otel_http_port: EVAL_OTEL_HTTP_PORT
  eval.fluent_bit_port: EVAL_FLUENT_BIT_PORT
  eval.zookeeper_tag: EVAL_ZOOKEEPER_TAG
  eval.clickhouse_tag: EVAL_CLICKHOUSE_TAG
  eval.schema_migrator_tag: EVAL_SCHEMA_MIGRATOR_TAG
  eval.otel_collector_tag: EVAL_OTEL_COLLECTOR_TAG
  eval.signoz_tag: EVAL_SIGNOZ_TAG
  eval.timescaledb_tag: EVAL_TIMESCALEDB_TAG
  eval.phoenix_tag: EVAL_PHOENIX_TAG
  eval.fluent_bit_tag: EVAL_FLUENT_BIT_TAG
YAML

dc_bump
dc_export
