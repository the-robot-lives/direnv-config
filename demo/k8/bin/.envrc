# demo/k8/bin/.envrc — Utility scripts directory
source_up
PATH_add "${INFRA_ROOT}/utils"

dc_yaml --no-bump _dc <<'YAML'
aliases:
  NOIZU_REGISTRY_USER: OPS_REGISTRY_USER
  NOIZU_REGISTRY_PASSWORD: OPS_REGISTRY_PASSWORD
  DOCKER_USER: DOCKERHUB_USER
  DOCKER_PASSWORD: DOCKERHUB_PASSWORD
YAML
dc_bump
dc_export
