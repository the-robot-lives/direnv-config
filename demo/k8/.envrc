# demo/k8/.envrc — Root of K8s infra repo
# Demonstrates: 8 consolidated named configs, wildcard flatten, aliases
# This is a migration reference for a real repo with ~190 env vars

PATH_add ./utils/

# --- Config 1: infra (base layer) ---
dc_yaml --no-bump infra <<'YAML'
root: /path/to/infra/k8
k8_lib_dir: /path/to/k8-lib
build_env: prod
npl_project: noizu-infra
YAML

# --- Config 2: cluster (base layer) ---
dc_yaml --no-bump cluster <<'YAML'
kubeconfig: ~/.kube/noizu/config
context: noizu
YAML

# --- Config 3: cf (base layer) ---
# Named "cf" so auto-derive gives CF_* prefix
dc_yaml --no-bump cf <<'YAML'
account_id: a75e7459-placeholder
zone_id: 46014d24-placeholder
zone_id_trl: 9793b993-placeholder
access:
  client_id: 7ebfc690-placeholder.access
YAML

# --- Config 4: secrets (sub-keyed, all credentials) ---
# Sub-keys match env var prefixes for wildcard flatten
dc_yaml --no-bump secrets --layer secrets --if-missing <<'YAML'
infisical:
  host: "https://infisical.example.com/api"
  project_slug: k8-infra
  env: prod
  namespace: infisical
  postgres_password: ""
  postgres_admin_password: ""
  redis_password: ""
  google_client_id: ""
  google_client_secret: ""
  system_email: ""
  encryption_key: ""
  auth_secret: ""
  site_url: ""
  create_ingress: false
  redis_url: ""
  db_connection_uri: ""
operator:
