# --- Config 9: tab ---
dc_yaml --no-bump tab <<'YAML'
theme: mahogany
YAML

# --- Config 10: _dc (flatten rules + aliases) ---
dc_yaml --no-bump _dc <<'YAML'
export:
  - infra
  - cluster
  - cf
  - secrets
  - platform
  - services
  - { name: auto, prefix: "" }
  - tab

flatten:
  # infra exceptions (auto-derive gives INFRA_K8_LIB_DIR, want K8_LIB_DIR)
  infra.k8_lib_dir: K8_LIB_DIR
  infra.build_env: BUILD_ENV
  infra.npl_project: NPL_PROJECT

  # cluster (both are exceptions)
  cluster.kubeconfig: KUBECONFIG
  cluster.context: KUBECTX_CURRENT_CONTEXT

  # cf exceptions (most auto-derive correctly as CF_*)
  cf.zone_id_trl: CF_ZONE_ID_THEROBOTLIVES
  cf.namecheap_trl_token: NAMECHEAP_TRL_TOKEN

  # secrets wildcards (sub-key name = env var prefix)
  secrets.infisical.*: INFISICAL_*
  secrets.operator.*: OPERATOR_*
  secrets.google.*: GOOGLE_*
  secrets.sendgrid.*: SENDGRID_*
  secrets.smtp.*: SMTP_*
  secrets.hf.*: HF_*
  secrets.github.*: GITHUB_*

  # secrets.registry (varied prefixes, need individual rules)
  secrets.registry.noizu_user: NOIZU_REGISTRY_USER
  secrets.registry.noizu_password: NOIZU_REGISTRY_PASSWORD
  secrets.registry.dockerhub_user: DOCKERHUB_USER
  secrets.registry.dockerhub_password: DOCKERHUB_PASSWORD
  secrets.registry.ops_user: OPS_REGISTRY_USER
  secrets.registry.ops_password: OPS_REGISTRY_PASSWORD

  # secrets.tls (env vars are SERVICE_TLS_CRT, not TLS_SERVICE_CRT)
  secrets.tls.crt: TLS_CRT
  secrets.tls.key: TLS_KEY
  secrets.tls.alt_key: ALT_TLS_KEY
  secrets.tls.cloudflare_ca_crt: CLOUDFLARE_CA_CRT
  secrets.tls.cloudflare_trb_ca_crt: CLOUDFLARE_TRB_CA_CRT
  secrets.tls.trl_cert: TRL_TLS_CERT
  secrets.tls.trl_key: TRL_TLS_KEY
  secrets.tls.registry_crt_file: REGISTRY_TLS_CRT_FILE
  secrets.tls.registry_key_file: REGISTRY_TLS_KEY_FILE
  secrets.tls.registry_crt: REGISTRY_TLS_CRT
  secrets.tls.registry_key: REGISTRY_TLS_KEY
  secrets.tls.codefresh_crt: CODEFRESH_TLS_CRT
  secrets.tls.codefresh_key: CODEFRESH_TLS_KEY
  secrets.tls.iotgo_crt: IOTGO_TLS_CRT
  secrets.tls.iotgo_key: IOTGO_TLS_KEY
  secrets.tls.aifighter_crt: AIFIGHTER_TLS_CRT
  secrets.tls.aifighter_key: AIFIGHTER_TLS_KEY
  secrets.tls.therobotlives_crt: THEROBOTLIVES_TLS_CRT
  secrets.tls.therobotlives_key: THEROBOTLIVES_TLS_KEY
  secrets.tls.jailbreakingsite_crt: JAILBREAKINGSITE_TLS_CRT
  secrets.tls.jailbreakingsite_key: JAILBREAKINGSITE_TLS_KEY
  secrets.tls.gottacc_crt: GOTTACC_TLS_CRT
  secrets.tls.gottacc_key: GOTTACC_TLS_KEY
  secrets.tls.noizurpg_crt: NOIZURPG_TLS_CRT
  secrets.tls.noizurpg_key: NOIZURPG_TLS_KEY
  secrets.tls.robots_unite_crt: ROBOTS_UNITE_TLS_CRT
  secrets.tls.robots_unite_key: ROBOTS_UNITE_TLS_KEY
  secrets.tls.noizu_ink_crt: NOIZU_INK_TLS_CRT
  secrets.tls.noizu_ink_key: NOIZU_INK_TLS_KEY

  # platform wildcards
  platform.headlamp.*: HEADLAMP_*
  platform.webui.*: WEBUI_*
  platform.jupyter.*: JUPYTER_*

  # platform individual
  platform.admin.cockpit_internal_ip: COCKPIT_INTERNAL_IP
  platform.admin.cockpit_port: COCKPIT_PORT
  platform.admin.cockpit_domain: COCKPIT_DOMAIN
  platform.weaviate.authentication_apikey_allowed_keys: AUTHENTICATION_APIKEY_ALLOWED_KEYS
  platform.dns.trl_cloudflare_account_id: TRL_CLOUDFLARE_ACCOUNT_ID
  platform.dns.derobot_zone: DEROBOT_ZONE
  platform.dns.therobotknows_zone: THEROBOTKNOWS_ZONE
  platform.dns.therobotmakes_zone: THEROBOTMAKES_ZONE
  platform.dns.therobotsrise_zone: THEROBOTSRISE_ZONE
  platform.dns.therobotstates_zone: THEROBOTSTATES_ZONE

  # services wildcards (where sub-key = env var prefix)
  services.telemetry.*: TELEMETRY_*
  services.livebook.*: LIVEBOOK_*
  services.bob.*: BOB_*
  services.apps.*: APPS_*

  # services.design (varied prefixes — PENPOT_*, DRAWIO_*, WEBSTUDIO_*, N8N_*, etc.)
  services.design.postgres_user: DESIGN_POSTGRES_USER
  services.design.postgres_password: DESIGN_POSTGRES_PASSWORD
  services.design.penpot_db_user: PENPOT_DB_USER
  services.design.penpot_db_password: PENPOT_DB_PASSWORD
  services.design.penpot_secret_key: PENPOT_SECRET_KEY
  services.design.penpot_google_client_id: PENPOT_GOOGLE_CLIENT_ID
  services.design.penpot_google_client_secret: PENPOT_GOOGLE_CLIENT_SECRET
  services.design.redis_password: DESIGN_REDIS_PASSWORD
  services.design.minio_root_user: MINIO_ROOT_USER
  services.design.minio_root_password: MINIO_ROOT_PASSWORD
  services.design.rabbitmq_user: DESIGN_RABBITMQ_USER
  services.design.rabbitmq_password: DESIGN_RABBITMQ_PASSWORD
  services.design.drawio_google_client_id: DRAWIO_GOOGLE_CLIENT_ID
  services.design.drawio_google_client_secret: DRAWIO_GOOGLE_CLIENT_SECRET
  services.design.drawio_google_app_id: DRAWIO_GOOGLE_APP_ID
  services.design.drawio_msgraph_client_id: DRAWIO_MSGRAPH_CLIENT_ID
  services.design.drawio_msgraph_client_secret: DRAWIO_MSGRAPH_CLIENT_SECRET
  services.design.drawio_msgraph_tenant_id: DRAWIO_MSGRAPH_TENANT_ID
  services.design.webstudio_db_user: WEBSTUDIO_DB_USER
  services.design.webstudio_db_password: WEBSTUDIO_DB_PASSWORD
  services.design.webstudio_auth_secret: WEBSTUDIO_AUTH_SECRET
  services.design.webstudio_postgrest_jwt_secret: WEBSTUDIO_POSTGREST_JWT_SECRET
  services.design.webstudio_google_client_id: WEBSTUDIO_GOOGLE_CLIENT_ID
  services.design.webstudio_google_client_secret: WEBSTUDIO_GOOGLE_CLIENT_SECRET
  services.design.webstudio_dev_login: WEBSTUDIO_DEV_LOGIN
  services.design.n8n_db_user: N8N_DB_USER
  services.design.n8n_db_password: N8N_DB_PASSWORD
  services.design.n8n_encryption_key: N8N_ENCRYPTION_KEY
  services.design.ghost_db_user: GHOST_DB_USER
  services.design.ghost_db_password: GHOST_DB_PASSWORD
  services.design.langfuse_db_user: LANGFUSE_DB_USER
  services.design.langfuse_db_password: LANGFUSE_DB_PASSWORD
  services.design.postiz_db_user: POSTIZ_DB_USER
  services.design.postiz_db_password: POSTIZ_DB_PASSWORD

  # services.mail (MAILU_*, ROUNDCUBE_*, bare POSTGRES_/REDIS_)
  services.mail.mailu_secret_key: MAILU_SECRET_KEY
  services.mail.mailu_admin_password: MAILU_ADMIN_PASSWORD
  services.mail.postgres_password: POSTGRES_PASSWORD
  services.mail.mailu_db_user: MAILU_DB_USER
  services.mail.mailu_db_password: MAILU_DB_PASSWORD
  services.mail.roundcube_db_user: ROUNDCUBE_DB_USER
  services.mail.roundcube_db_password: ROUNDCUBE_DB_PASSWORD
  services.mail.redis_password: REDIS_PASSWORD

  # services.operations
  services.operations.erpnext_mariadb_root_password: ERPNEXT_MARIADB_ROOT_PASSWORD
  services.operations.erpnext_admin_password: ERPNEXT_ADMIN_PASSWORD

  # services.svc (misc — every key has its own prefix)
  services.svc.registry_htpasswd: REGISTRY_HTPASSWD
  services.svc.haka_postgres_password: HAKA_POSTGRES_PASSWORD
  services.svc.code_server_password: CODE_SERVER_PASSWORD
  services.svc.serpbear_user: SERPBEAR_USER
  services.svc.serpbear_password: SERPBEAR_PASSWORD
  services.svc.serpbear_secret: SERPBEAR_SECRET
  services.svc.serpbear_apikey: SERPBEAR_APIKEY
  services.svc.ghost_db_password: GHOST_DB_PASSWORD
  services.svc.ghost_db_user: GHOST_DB_USER
  services.svc.livecodes_redis_url: LIVECODES_REDIS_URL
  services.svc.services_mysql_root_password: SERVICES_MYSQL_ROOT_PASSWORD
  services.svc.langfuse_database_url: LANGFUSE_DATABASE_URL
  services.svc.langfuse_nextauth_secret: LANGFUSE_NEXTAUTH_SECRET
  services.svc.langfuse_salt: LANGFUSE_SALT
  services.svc.langfuse_encryption_key: LANGFUSE_ENCRYPTION_KEY
  services.svc.matomo_db_password: MATOMO_DB_PASSWORD
  services.svc.label_studio_username: LABEL_STUDIO_USERNAME
  services.svc.label_studio_password: LABEL_STUDIO_PASSWORD
  services.svc.mautic_db_password: MAUTIC_DB_PASSWORD
  services.svc.mautic_secret_key: MAUTIC_SECRET_KEY
  services.svc.postiz_database_url: POSTIZ_DATABASE_URL
  services.svc.postiz_redis_url: POSTIZ_REDIS_URL
  services.svc.postiz_jwt_secret: POSTIZ_JWT_SECRET
  services.svc.espocrm_db_password: ESPOCRM_DB_PASSWORD
  services.svc.espocrm_admin_username: ESPOCRM_ADMIN_USERNAME
  services.svc.espocrm_admin_password: ESPOCRM_ADMIN_PASSWORD
  services.svc.growthbook_mongodb_uri: GROWTHBOOK_MONGODB_URI
  services.svc.growthbook_jwt_secret: GROWTHBOOK_JWT_SECRET
  services.svc.growthbook_encryption_key: GROWTHBOOK_ENCRYPTION_KEY
  services.svc.seonaut_db_password: SEONAUT_DB_PASSWORD
  services.svc.bottlecrm_db_password: BOTTLECRM_DB_PASSWORD
  services.svc.bottlecrm_database_url: BOTTLECRM_DATABASE_URL
  services.svc.bottlecrm_secret_key: BOTTLECRM_SECRET_KEY
  services.svc.bottlecrm_google_client_id: BOTTLECRM_GOOGLE_CLIENT_ID
  services.svc.bottlecrm_google_client_secret: BOTTLECRM_GOOGLE_CLIENT_SECRET
  services.svc.bottlecrm_email_password: BOTTLECRM_EMAIL_PASSWORD
  services.svc.listmonk_db_password: LISTMONK_DB_PASSWORD
  services.svc.listmonk_admin_username: LISTMONK_ADMIN_USERNAME
  services.svc.listmonk_admin_password: LISTMONK_ADMIN_PASSWORD

  # auto (strip prefix)
  auto.*: "*"

  # tab
  tab.*: TAB_*

aliases:
  SMTP_PASSWORD: SENDGRID_API_KEY
  K8_INFISICAL_HOST: INFISICAL_HOST
  K8_INFISICAL_CLIENT_ID: OPERATOR_CLIENT_ID
  K8_INFISICAL_CLIENT_SECRET: OPERATOR_CLIENT_SECRET
  HF_TOKEN: HF_READ_TOKEN
  GITHUB_CLIENT_SECRET: GITHUB_TOKEN
  GITHUB_API_KEY: GITHUB_TOKEN
  DOCKER_USER: DOCKERHUB_USER
  DOCKER_PASSWORD: DOCKERHUB_PASSWORD
YAML

dc_bump

dc_export

# Runtime: file-based cert population (can't be YAML)
export REGISTRY_TLS_CRT="$(cat "$REGISTRY_TLS_CRT_FILE" 2>/dev/null)"
export REGISTRY_TLS_KEY="$(cat "$REGISTRY_TLS_KEY_FILE" 2>/dev/null)"
