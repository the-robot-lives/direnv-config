  port: "587"
  user: apikey
  from: noreply@example.com
  use_tls: "true"
  use_ssl: "false"
  default_reply_to: admin@example.com
registry:
  noizu_user: ""
  noizu_password: ""
  dockerhub_user: ""
  dockerhub_password: ""
  ops_user: ""
  ops_password: ""
hf:
  read_token: ""
github:
  token: ""
tls:
  crt: ""
  key: ""
  alt_key: ""
  cloudflare_ca_crt: ""
  cloudflare_trb_ca_crt: ""
  trl_cert: ""
  trl_key: ""
  registry_crt_file: ""
  registry_key_file: ""
  registry_crt: ""
  registry_key: ""
  codefresh_crt: ""
  codefresh_key: ""
  iotgo_crt: ""
  iotgo_key: ""
  aifighter_crt: ""
  aifighter_key: ""
  therobotlives_crt: ""
  therobotlives_key: ""
  jailbreakingsite_crt: ""
  jailbreakingsite_key: ""
  gottacc_crt: ""
  gottacc_key: ""
  noizurpg_crt: ""
  noizurpg_key: ""
  robots_unite_crt: ""
  robots_unite_key: ""
  noizu_ink_crt: ""
  noizu_ink_key: ""
YAML

# --- Config 5: platform (base + secrets) ---
dc_yaml --no-bump platform <<'YAML'
headlamp:
  namespace: headlamp-ns
  domain: headlamp.example.com
webui:
  namespace: webui-ns
jupyter:
  namespace: jupyter-ns
  domain: jupyter.example.com
admin:
  cockpit_internal_ip: "10.1.0.1"
  cockpit_port: "9090"
  cockpit_domain: cockpit.example.com
dns:
  derobot_zone: placeholder-zone-id
  therobotknows_zone: placeholder-zone-id
  therobotmakes_zone: placeholder-zone-id
  therobotsrise_zone: placeholder-zone-id
  therobotstates_zone: placeholder-zone-id
YAML

dc_yaml --no-bump platform --layer secrets --if-missing <<'YAML'
weaviate:
  authentication_apikey_allowed_keys: ""
dns:
  trl_cloudflare_account_id: ""
YAML

