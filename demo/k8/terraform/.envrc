# demo/k8/terraform/.envrc — Terraform / IaC directory
# Demonstrates: heavy pruning, child-specific config, aliases for TF_VAR_*
source_up

# Prune configs terraform doesn't need
dc_prune --no-bump secrets
dc_prune --no-bump platform
dc_prune --no-bump services
dc_prune --no-bump auto

# Terraform-specific provider credentials
dc_yaml --no-bump terraform --layer secrets --if-missing <<'YAML'
noizu:
  cloudflare_api_token: ""
  namecheap_api_token: ""
trl:
  cloudflare_api_token: ""
  namecheap_api_token: ""
namecheap:
  noizu_user: KeithNoizu
  noizu_api_user: KeithNoizu
  trl_user: TheRobotIsMe
  trl_api_user: TheRobotIsMe
YAML

# Override cluster kubeconfig for terraform context
dc_yaml --no-bump cluster <<'YAML'
kubeconfig: ~/.kube/config
YAML

dc_yaml --no-bump tab <<'YAML'
theme: nord
status: terraform
YAML

dc_yaml --no-bump _dc <<'YAML'
flatten:
  terraform.noizu.cloudflare_api_token: CF_NOIZU_API_TOKEN
  terraform.noizu.namecheap_api_token: NC_NOIZU_API_TOKEN
  terraform.trl.cloudflare_api_token: CF_TRL_API_TOKEN
  terraform.trl.namecheap_api_token: NC_TRL_API_TOKEN
  terraform.namecheap.noizu_user: NAMECHEAP_NOIZU_USER
  terraform.namecheap.noizu_api_user: NAMECHEAP_NOIZU_API_USER
  terraform.namecheap.trl_user: NAMECHEAP_TRL_USER
  terraform.namecheap.trl_api_user: NAMECHEAP_TRL_API_USER
  cluster.kubeconfig: K8_CONFIG

aliases:
  TF_VAR_noizu_cloudflare_api_token: CF_NOIZU_API_TOKEN
  TF_VAR_trl_cloudflare_api_token: CF_TRL_API_TOKEN
  TF_VAR_noizu_namecheap_api_key: NC_NOIZU_API_TOKEN
  TF_VAR_trl_namecheap_api_key: NC_TRL_API_TOKEN
  TF_VAR_noizu_namecheap_user_name: NAMECHEAP_NOIZU_USER
  TF_VAR_noizu_namecheap_api_user: NAMECHEAP_NOIZU_API_USER
  TF_VAR_trl_namecheap_user_name: NAMECHEAP_TRL_USER
  TF_VAR_trl_namecheap_api_user: NAMECHEAP_TRL_API_USER
  CF_NOIZU_API_ACCOUNT: CF_NOIZU_API_TOKEN
YAML

dc_bump
dc_export
